# ============================================
# Bot de YouTube para Telegram - Example
# ============================================

# Credenciales de Telegram (obtener de https://my.telegram.org)
API_ID=your_api_id
API_HASH=your_api_hash
USUARIOS_AUTORIZADOS=user_id1,user_id2

# Número de teléfono para autenticación
PHONE=+1234567890

# Configuración del bot
CARPETA_DESCARGAS=./downloads
MAX_HEIGHT=720
LOG_LEVEL=INFO

# Tiempo de retención de archivos (horas) - 168 = 7 días
CLEANUP_HOURS=168

# Grupo destino para enviar descargas (ID del grupo - con signo negativo)
GRUPO_DESTINO=-123456789
